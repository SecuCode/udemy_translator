{
  "manifest_version": 3,
  "name": "Udemy Live Translator (Local)",
  "version": "1.1",
  "description": "Translate Udemy captions into Korean using your local NLLB translation server.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.udemy.com/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
